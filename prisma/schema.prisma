generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ══════════════════════════════════════════════
// AUTH & RBAC
// ══════════════════════════════════════════════

model User {
  tabel_id      String    @id
  full_name     String
  password_hash String    @default("")
  is_head_admin Boolean   @default(false)
  role_id       String    @db.Uuid
  role          Role      @relation(fields: [role_id], references: [id])
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  users       User[]
  permissions RolePermission[]
}

model RolePermission {
  id          String  @id @default(uuid()) @db.Uuid
  role_id     String  @db.Uuid
  action_name String
  is_allowed  Boolean @default(false)

  role Role @relation(fields: [role_id], references: [id])

  @@unique([role_id, action_name])
}

// ══════════════════════════════════════════════
// DICTIONARIES (Справочники)
// ══════════════════════════════════════════════

enum SubjectType {
  P // Physical person
  J // Juridical entity
}

model Client {
  id          String      @id @default(uuid()) @db.Uuid
  code        String      @unique
  name        String
  subject     SubjectType
  code_filial String
  inn         String      @unique
  address     String      @default("")
  phone       String      @default("")
  condition   Boolean     @default(true) // true=active, false=passive

  accounts         Account[]
  leases_as_tenant Lease[]   @relation("LeaseTenant")
  leases_as_lessor Lease[]   @relation("LeaseLessor")

  @@index([code_filial])
  @@index([inn])
}

enum AccountType {
  INCOME
  EXPENSE
  TRANSIT
}

model CBURegistry {
  id           String      @id @default(uuid()) @db.Uuid
  coa_code     String      @unique @db.VarChar(5)
  description  String
  account_type AccountType

  @@map("cbu_registry")
}

model Account {
  id            String @id @default(uuid()) @db.Uuid
  client_id     String @db.Uuid
  code          String @unique @db.VarChar(20) // 20-digit account code
  code_filial   String
  code_coa      String @db.VarChar(5) // first 5 digits of code
  code_currency String @default("000") // e.g. '000' (UZS), '840' (USD)

  client Client @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@index([code_coa])
}

// ══════════════════════════════════════════════
// LEASE MANAGEMENT (Шартномалар)
// ══════════════════════════════════════════════

enum LeaseType {
  OUTBOUND // Bank rents out (Сдача в аренду)
  INBOUND  // Bank rents in (Получение в аренду)
}

enum LeaseStatus {
  INTRODUCED
  APPROVED
  RETURNED
}

model Lease {
  id                     String      @id @default(uuid()) @db.Uuid
  type                   LeaseType
  status                 LeaseStatus @default(INTRODUCED)
  asset_type             String
  measurement_unit       String
  amount                 Decimal     @db.Decimal(15, 2)
  tenant_id              String      @db.Uuid
  lessor_id              String      @db.Uuid
  income_expense_account String      @db.VarChar(20)
  transit_account        String      @db.VarChar(20)
  start_date             DateTime
  end_date               DateTime
  created_at             DateTime    @default(now())

  tenant      Client      @relation("LeaseTenant", fields: [tenant_id], references: [id])
  lessor      Client      @relation("LeaseLessor", fields: [lessor_id], references: [id])
  memo_orders MemoOrder[]
  scheduled_payments ScheduledPayment[]

  @@index([type])
  @@index([status])
  @@index([tenant_id])
  @@index([lessor_id])
}

model MemoOrder {
  id                String   @id @default(uuid()) @db.Uuid
  lease_id          String   @db.Uuid
  debit_account_20  String   @db.VarChar(20)
  credit_account_20 String   @db.VarChar(20)
  amount            Decimal  @db.Decimal(15, 2)
  generated_at      DateTime @default(now())

  lease Lease @relation(fields: [lease_id], references: [id])

  @@index([lease_id])
}

// ══════════════════════════════════════════════
// AUDIT LOG (Протокол)
// ══════════════════════════════════════════════

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tabel_id  String
  action    String
  entity    String
  entity_id String   @db.Uuid
  payload   Json?
  timestamp DateTime @default(now())

  @@index([entity, entity_id])
  @@index([tabel_id])
}

// ══════════════════════════════════════════════
// PAYMENT QUEUE (Очередь платежей)
// ══════════════════════════════════════════════

model ScheduledPayment {
  id             String   @id @default(uuid()) @db.Uuid
  lease_id       String   @db.Uuid
  amount         Decimal  @db.Decimal(15, 2)
  scheduled_date DateTime
  status         String   @default("PENDING") // PENDING, COMPLETED, FAILED
  created_at     DateTime @default(now())

  lease Lease @relation(fields: [lease_id], references: [id])

  @@index([status])
  @@index([scheduled_date])
}
