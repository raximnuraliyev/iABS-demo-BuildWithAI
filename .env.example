# ── Database ──
DATABASE_URL="postgresql://iabs:password@localhost:5432/arundacore?schema=public"

# ── Auth ──
JWT_SECRET=change-me-to-a-strong-random-secret
CSRF_SECRET=change-me-to-a-strong-random-secret

# ── CORS ──
CORS_ORIGIN=http://localhost:3000

# ── Google AI (Gemini) ──
GOOGLE_AI_API_KEY=your-google-ai-api-key
GCP_PROJECT_ID=your-gcp-project-id

# ── Comet API (Real Estate Matchmaker) ──
COMET_API_KEY=your-comet-api-key

# ── Server ──
PORT=3001
NODE_ENV=development
